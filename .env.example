# Firebase Configuration
# Copy this file to .env and fill in your Firebase project values
# Get these from Firebase Console → Project Settings → Web App

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Course sale end date (ISO string with timezone)
# VITE_SALE_END=2026-07-31T23:59:59+03:00
